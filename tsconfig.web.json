{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "types": ["vite/client"],
    "paths": {
      "@shared/*": ["src/shared/*"],
      "@renderer/*": ["src/renderer/src/*"]
    }
  },
  "include": [
    "src/renderer/**/*",
    "src/shared/**/*",
    "tests/unit/renderer/**/*",
    "tests/unit/shortcuts/**/*",
    "tests/unit/overlay/**/*"
  ],
  "exclude": ["node_modules", "out"]
}
